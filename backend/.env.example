# ── PostgreSQL (app database) ──────────────────────────────────────────────
# Required — no defaults
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bi_assistant
DB_USER=bi_user
DB_PASSWORD=change_me

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# ── Logging ────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=logs
APP_ENV=development

# ── HR BI pipeline ─────────────────────────────────────────────────────────
# Path to the metadata directory (relative to backend/)
METADATA_DIR=./metadata
CURRENT_SHAMSI_YEAR=1404

# false = generate SQL only, do not execute against the HR database
DEFAULT_EXECUTE_SQL=false

# SQL generation strategy flags
USE_TEMPLATE_ENGINE=true
USE_CONTROLLED_DYNAMIC=true
FORCE_LLM_FOR_INCOMPLETE_TEMPLATE=false
ENABLE_LLM_SQL_FALLBACK=true

# true = run the Phase 2 SQL validator before executing a query from /chat/query
VALIDATE_SQL_BEFORE_EXECUTION=true

# ── Ollama and query database ───────────────────────────────────────────────
# Configured at runtime via Settings UI (Settings → Ollama, Settings → Database)
# No env vars needed here.
