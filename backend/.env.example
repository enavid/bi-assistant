# Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_TAGS_URL=http://localhost:11434/api/tags
MODEL_NAME=llama3-sqlcoder
MODEL_TEMPERATURE=0.4
MODEL_TOP_P=0.5
MODEL_TIMEOUT=120

# ── PostgreSQL (app database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bi_assistant
DB_USER=bi_user
DB_PASSWORD=change_me

# ── PostgreSQL (HR data)
HR_DB_HOST=localhost
HR_DB_PORT=5432
HR_DB_NAME=hr_database
HR_DB_USER=hr_user
HR_DB_PASSWORD=change_me

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Logging
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=logs
APP_ENV=development

# HR BI
HR_BI_METADATA_DIR=./metadata
CURRENT_SHAMSI_YEAR=1404

# false = only generate SQL, do not execute against DB
DEFAULT_EXECUTE_SQL=false

# true = allow LLM fallback when no template matches
ENABLE_LLM_SQL_FALLBACK=true

# false = keep old /chat/generate working as before
# true  = route /chat/generate through Phase 2 pipeline
HR_BI_V2_ON_GENERATE=false

# true = validate SQL with Phase 2 validator before /chat/query runs it
HR_BI_VALIDATE_QUERY_V2=true

# Frontend
VITE_API_URL=/api

# HTTP ports (docker-compose)
HTTP_PORT=8088
HTTPS_PORT=6443
