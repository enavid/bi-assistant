# ── Ollama ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_TAGS_URL=http://localhost:11434/api/tags
MODEL_NAME=llama3-sqlcoder
MODEL_TEMPERATURE=0.4
MODEL_TOP_P=0.5
MODEL_TIMEOUT=120

# ── PostgreSQL (app database) ─────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bi_assistant
DB_USER=bi_user
DB_PASSWORD=change_me

# ── PostgreSQL (HR data — for running SQL queries) ────────
HR_DB_HOST=localhost
HR_DB_PORT=5432
HR_DB_NAME=hr_database
HR_DB_USER=hr_user
HR_DB_PASSWORD=change_me

# ── API ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── Frontend ──────────────────────────────────────────────
VITE_API_URL=/api
